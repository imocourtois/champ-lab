{
  "name": "champ-lab",
  "version": "0.1.0",
  "license": "MIT",
  "tasks": {
    "dev": "deno run -A --watch=static/,routes/,islands/,components/,lib/,data/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A main.ts",
    "check": "deno fmt --check && deno lint && deno check",
    "test": "deno test -A"
  },
  "lint": {
    "rules": { "tags": ["fresh", "recommended"] }
  },
  "fmt": {
    "lineWidth": 110
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "fresh": "jsr:@fresh/core@^2.0.0",
    "fresh/dev": "jsr:@fresh/core@^2.0.0/dev",
    "fresh/runtime": "jsr:@fresh/core@^2.0.0/runtime",
    "preact": "npm:preact@^10.24.0",
    "preact/hooks": "npm:preact@^10.24.0/hooks",
    "@preact/signals": "npm:@preact/signals@^1.3.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@/": "./"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "preact"
  }
}
